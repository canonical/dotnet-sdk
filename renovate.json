{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],
  "enabledManagers": [
    "custom.regex"
  ],
  "customManagers": [
    {
      "customType": "regex",
      "managerFilePatterns": ["/^VERSION$/"],
      "matchStrings": [
        "(?<currentValue>[0-9.]+)"
      ],
      "depNameTemplate": "dotnet/sdk",
      "datasourceTemplate": "github-releases",
      "extractVersionTemplate": "^v(?<version>.*)$",
      "versioningTemplate": "semver"
    }
  ],
  "baseBranchPatterns": [
    "8",
    "9",
    "10"
  ],
  "packageRules": [
    {
      "matchPackageNames": ["dotnet/sdk"],
      "matchBaseBranches": ["8"],
      "allowedVersions": "/^8\\./"
    },
    {
      "matchPackageNames": ["dotnet/sdk"],
      "matchBaseBranches": ["9"],
      "allowedVersions": "/^9\\./"
    },
    {
      "matchPackageNames": ["dotnet/sdk"],
      "matchBaseBranches": ["10"],
      "allowedVersions": "/^10\\./"
    }
  ]
}
